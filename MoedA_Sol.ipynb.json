     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[1], [1, 2, 4, 8], [1, 2, 4, 5, 10, 20], [1, 5, 7, 35]]\n"
     ]
    }
   ],
   "source": [
    "print(divisors(1,8,20,35))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5c242654-ce22-4cbf-a50c-bf9f106fa4a7",
