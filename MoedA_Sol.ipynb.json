   "outputs": [],
   "source": [
    "words = {}\n",
    "for line in Decrypted:\n",
    "    line = line.split(' ')\n",
    "    for word in line:\n",
    "        words[word] = words.get(word, 0) + 1\n",
    "words_list = [[freq, word] for word, freq in words.items()] # easier to sort a list instead of dictionary\n",
    "words_list = sorted(words_list, reverse=True)[:10] # decreasing order, first 10 words\n",
    "\n",
    "words_top10 = [item[1] for item in words_list] \n",
    "words_top10_freq = [item[0] for item in words_list] \n",
    "\n",
    "\n",
    "plt.bar(words_top10, words_top10_freq)\n",
    "plt.title('Most Common words\")\n",
    "plt.show()"
   ]
