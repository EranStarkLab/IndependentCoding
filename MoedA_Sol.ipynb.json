   "source": [
    "Encrypted = open('EncryptedText.txt')\n",
    "Decrypted = open('Decrypted.txt', 'w')\n",
    "\n",
    "translation = {'a':'c', \n",
    "               'b':'d', \n",
    "               'c':'e',\n",
    "               'd':'f',\n",
    "               'e':'g',\n",
    "               'f':'h',\n",
    "               'g':'i',\n",
    "               'h':'j',\n",
    "               'i':'k',\n",
    "               'j':'l',\n",
    "               'k':'m',\n",
    "               'l':'n',\n",
    "               'm':'o',\n",
    "               'n':'p',\n",
    "               'o':'q',\n",
    "               'p':'r',\n",
    "               'q':'s',\n",
    "               'r':'t',\n",
    "               's':'u',\n",
    "               't':'v',\n",
    "               'u':'w',\n",
    "               'v':'x',\n",
    "               'w':'y',\n",
    "               'x':'z',\n",
    "               'y':'a',\n",
    "               'z':'b'}\n",
    "\n",
    "for line in Encrypted:\n",
    "    translated_line = ''\n",
    "    for letter in line:\n",
    "        if letter == ' ': # space\n",
    "            translated_line += ' '\n",
    "        elif letter == '\\n': # Solutions without conditions for spaces and new lines will are considered as correct\n",
    "            translated_line += '\\n'\n",
    "        else:\n",
    "            translated_line += translation[letter]\n",
    "    Decrypted.write(translated_line) # no need to add \"\\n\" because every line in txt files ends with \\n.\n",
    "\n",
    "Encrypted.close()\n",
    "Decrypted.close()"
   ]
  },
