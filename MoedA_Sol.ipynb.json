   "source": [
    "def divisors(*nums):\n",
    "    res = []\n",
    "    for num in nums:\n",
    "        div = []\n",
    "        for i in range(1, num+1):\n",
    "            if num % i == 0:\n",
    "                div.append(i)\n",
    "        res.append(div)\n",
    "    return res"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "619d0881-d123-4758-892a-cdf53e6cacac",
   "metadata": {},
   "outputs": [
