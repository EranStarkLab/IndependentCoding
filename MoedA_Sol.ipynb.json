    "n = 10000\n",
    "success = 0\n",
    "initial_value = 50\n",
    "\n",
    "for rep in range(n):\n",
    "    A_val = initial_value\n",
    "    while 40 < A_val < 60:\n",
    "        p_for_up = random.random()\n",
    "        if p_for_up <= 0.5: # Stock goes down\n",
    "            A_val -= random.random()*12\n",
    "        else: # Stock goes up\n",
    "            A_val += random.random()*10\n",
    "    if A_val >= 60:\n",
    "        success +=1\n",
    "print(success/n)"
   ]
