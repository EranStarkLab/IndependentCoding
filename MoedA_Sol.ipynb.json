   "outputs": [],
   "source": [
    "def sum_divisors_above_k(*nums, k=100):\n",
    "    res = []\n",
    "    div = divisors(*nums) # solutions without the use of * here will be considered as correct! \n",
    "    for divs, num in zip(div, nums):\n",
    "        if sum(divs) > k:\n",
    "            res.append(num)\n",
    "    return res"
   ]
  },
